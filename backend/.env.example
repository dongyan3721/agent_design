# med_agent Environment Variables

# === Project ===
PROJECT_NAME=med_agent
DEBUG=true
ENVIRONMENT=local
# === MongoDB ===
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=med_agent
# MONGO_USER=
# MONGO_PASSWORD=
# === JWT Auth ===
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256
# === AI Agent (langchain, openai) ===OPENAI_API_KEY=
AI_MODEL=gpt-4o-miniAI_TEMPERATURE=0.7
# === LangSmith Observability ===
# Get your API key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=med_agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# === CORS ===
# JSON list of allowed origins (default: localhost:3000, localhost:8080)
# Note: "*" is blocked in production - specify explicit origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]